# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Integração ELOCA ↔ CRM Lovable
# Copie para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no git.
# No Fly.io use: fly secrets set CHAVE=valor
# ─────────────────────────────────────────────────────────────────────────────

# ── ELOCA ─────────────────────────────────────────────────────────────────────
ELOCA_URL=https://weback.app.otimogestor.com.br/
LOGIN_URL=https://api.otimogestor.com.br/
API_BASE=https://api.otimogestor.com.br
SISTEMA_BASE=https://sistema.otimogestor.com.br
CGI_BASE=https://weback.app.otimogestor.com.br/cgi-bin/exec.cgi

ELOCA_EMPRESA=weback      # Campo "Empresa" na tela de login
ELOCA_USER=seu_usuario_eloca
ELOCA_PASSWORD=sua_senha_eloca

# Onde o token é salvo (além da sessão do browser)
TOKEN_FILE=/tmp/eloca_token.json

# ── Supabase ──────────────────────────────────────────────────────────────────
# URL do projeto: Settings > API > Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Chave service_role (Settings > API > service_role) — NÃO use anon key aqui
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Nome do bucket no Supabase Storage (crie manualmente no dashboard)
SUPABASE_BUCKET=eloca-sync

# ── Agendamento ───────────────────────────────────────────────────────────────
# Formato cron padrão (minuto hora dia mês dia-semana)
# Exemplos:
#   */30 * * * *      → a cada 30 minutos
#   0 * * * *         → a cada hora
#   0 6,12,18 * * *   → às 6h, 12h e 18h
SYNC_CRON=*/30 * * * *

# Executa sincronização imediatamente ao iniciar o container?
RUN_ON_START=true

# ── 2captcha (login automático, sem browser, sem intervenção manual) ──────────
# Crie conta em https://2captcha.com, deposite crédito (~$3 para 1.000 logins)
# e copie a API key do painel.
# O login só acontece quando a sessão expira (raramente).
TWOCAPTCHA_API_KEY=sua_chave_2captcha_aqui

# Arquivos de sessão (no Fly.io: aponte para /data/ que é o volume persistente)
SESSION_FILE=/data/eloca_session.json
TOKEN_FILE=/data/eloca_token.json

# ── Playwright ────────────────────────────────────────────────────────────────
# Timeout em milissegundos para esperar elementos na página
PLAYWRIGHT_TIMEOUT_MS=30000
